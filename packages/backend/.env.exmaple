PORT=3000
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_key_here
MODEL_NAME=gpt-4o-mini
RATE_LIMIT_WINDOW=1
RATE_LIMIT=10
EDGE_API_LIMIT=10
DIRECT_GEN_LIMIT=200

# Edge TTS 代理配置（可选）
# 格式：http://username:password@proxy-server:port
# 或：socks5://username:password@proxy-server:port
# EDGE_TTS_PROXY=http://proxy.example.com:8080